alias ..="cd .."
alias rm="rm -rf --i"
alias ls='ls -a --color'
alias python='python -i'
alias vi='vim'
alias python3='python3 -i'

alias ls='ls -F --group-directories-first --color'
alias ll='ls -laF --group-directories-first --color'
alias grep='grep --color'

export PS1='\u@\h:\[\e[33m\]\w\[\e[0m\]\$ '
export EDITOR='vim'

